{
    "manifest_version": 3,
    "name": "OwnStep Proxy",
    "version": "1.0",
    "description": "Маршрутизация сайтов через VPN-прокси OwnStep",
    "permissions": [
        "proxy",
        "storage",
        "activeTab",
        "tabs"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup.html",
        "default_title": "OwnStep Proxy"
    }
}